  const simRoot = document.getElementById('tab-simulacion');
  const simLightbox = document.getElementById('simLightbox');
  const simLightboxImage = document.getElementById('simLightboxImage') as HTMLImageElement | null;
  const simLightboxClose = document.getElementById('simLightboxClose');

  const openSimLightbox = (image: HTMLImageElement) => {
    if (!simLightbox || !simLightboxImage) return;
    const rect = image.getBoundingClientRect();
    simLightbox.style.setProperty('--sim-open-img-width', `${Math.max(rect.width, 1)}px`);
    simLightbox.style.setProperty('--sim-open-img-height', `${Math.max(rect.height, 1)}px`);
    simLightboxImage.src = image.src;
    simLightboxImage.alt = image.alt || 'Vista ampliada';
    simLightbox.classList.add('is-open');
    simLightbox.setAttribute('aria-hidden', 'false');
  };

  const closeSimLightbox = () => {
    if (!simLightbox) return;
    simLightbox.classList.remove('is-open');
    simLightbox.setAttribute('aria-hidden', 'true');
  };

  if (simRoot) {
    const images = simRoot.querySelectorAll<HTMLImageElement>('img[data-sim-lightbox="true"]');
    images.forEach((image) => {
      image.setAttribute('role', 'button');
      image.setAttribute('tabindex', '0');
      image.setAttribute('aria-label', `Abrir imagen en grande: ${image.alt || 'imagen'}`);
      image.addEventListener('click', () => openSimLightbox(image));
      image.addEventListener('keydown', (event: KeyboardEvent) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          openSimLightbox(image);
        }
      });
    });
  }

  if (simLightboxClose) {
    simLightboxClose.addEventListener('click', (event: MouseEvent) => {
      event.stopPropagation();
      closeSimLightbox();
    });
  }

  if (simLightboxImage) {
    simLightboxImage.addEventListener('click', closeSimLightbox);
  }

  if (simLightbox) {
    simLightbox.addEventListener('click', (event: MouseEvent) => {
      if (event.target === simLightbox) {
        closeSimLightbox();
      }
    });
  }

document.addEventListener('keydown', (event: KeyboardEvent) => {
  if (event.key === 'Escape' && simLightbox && simLightbox.classList.contains('is-open')) {
    closeSimLightbox();
  }
});
</script>
