<!-- CSS COMPLETO GLOBAL - Estilos decorativos -->
<style is:global>
  /* Transiciones y efectos hover */
  .bis-slot-item {
    transition: all 0.2s ease;
  }

  .bis-slot-item:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 12px rgba(79, 195, 247, 0.15);
    transform: translateY(-1px);
  }

  /* Barras de calidad laterales */
  .bis-slot-bar {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 4px;
  }

  .bis-slot-item[data-quality="tier"] .bis-slot-bar {
    background: linear-gradient(180deg, #ff9800, #f57c00);
  }

  .bis-slot-item[data-quality="mplus"] .bis-slot-bar {
    background: linear-gradient(180deg, #ab47bc, #8e24aa);
  }

  .bis-slot-item[data-quality="craft"] .bis-slot-bar {
    background: linear-gradient(180deg, #43a047, #2e7d32);
  }

  .bis-slot-item[data-quality="raid"] .bis-slot-bar {
    background: linear-gradient(180deg, #4fc3f7, #0288d1);
  }

  .bis-slot-item[data-quality="cosmetic"] .bis-slot-bar {
    background: linear-gradient(180deg, #9e9e9e, #616161);
  }

  /* Checkbox */
  .bis-slot-content .bis-check {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    cursor: pointer;
    accent-color: var(--accent);
  }

  /* Iconos con hover */
  .bis-slot-icon {
    cursor: pointer;
    background: none;
    transition: all 0.2s ease;
  }

  .bis-slot-icon:hover {
    border-color: var(--accent);
    transform: scale(1.05);
  }

  .bis-sidebar-icon {
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .bis-sidebar-icon:hover {
    border-color: var(--accent);
    transform: scale(1.05);
  }

  /* Tipografía y enlaces */
  .bis-slot-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .bis-item-link {
    font-size: 15px;
    font-weight: 600;
    color: var(--purple);
    line-height: 1.3;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .bis-item-link:hover {
    color: var(--gold);
    text-decoration: underline;
  }

  .bis-item-source {
    font-size: 12px;
    color: var(--text2);
    line-height: 1.2;
  }

  .bis-item-cosmetic {
    color: var(--text2);
    font-style: italic;
  }

  .bis-item-cosmetic-label {
    font-size: 15px;
    font-weight: 600;
    color: var(--text2);
    font-style: italic;
  }

  /* Especialización central */
  .bis-spec-bg-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    border-radius: 8px;
  }

  .bis-spec-bg-wrap img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0.6;
  }

  .bis-spec-crest {
    position: relative;
    z-index: 1;
    width: 350px;
    height: auto;
    flex: 1;
    margin-top: 20px;
    object-fit: contain;
  }

  .bis-spec-name {
    position: relative;
    z-index: 1;
    margin-top: auto;
    padding-top: 8px;
  }

  /* Arma destacada */
  .bis-weapon-slot .bis-slot-item {
    background: linear-gradient(135deg, var(--bg3), var(--bg4));
    border: 2px solid var(--gold);
    box-shadow: 0 4px 16px rgba(244, 200, 66, 0.2);
  }

  .bis-weapon-slot .bis-slot-item:hover {
    border-color: var(--accent);
    box-shadow: 0 6px 20px rgba(79, 195, 247, 0.3);
  }

  .bis-weapon-slot .bis-slot-content {
    padding: 14px;
  }

  .bis-weapon-slot .bis-slot-icon {
    width: 52px;
    height: 52px;
  }

  .bis-weapon-slot .bis-slot-name {
    font-size: 14px;
    color: var(--gold);
  }

  .bis-weapon-slot .bis-item-link {
    font-size: 16px;
  }

  /* Sidebar */
  .bis-sidebar-section {
    overflow: hidden;
  }

  .bis-sidebar-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: linear-gradient(135deg, var(--bg4), var(--bg3));
    border-bottom: 1px solid var(--border2);
    color: var(--gold);
    font-family: 'Cinzel', serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.8px;
  }

  .bis-sidebar-item {
    transition: background 0.2s ease;
  }

  .bis-sidebar-item:hover {
    background: var(--card);
  }

  .bis-sidebar-slot {
    min-width: 70px;
    flex-shrink: 0;
    font-size: 12px;
    font-weight: 600;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .bis-enchant-link,
  .bis-consumable-link {
    flex: 1;
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    line-height: 1.3;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .bis-enchant-link:hover,
  .bis-consumable-link:hover {
    color: var(--gold);
    text-decoration: underline;
  }

  /* Progreso */
  .bis-progress-label {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
  }

  .bis-progress-count {
    min-width: 60px;
    font-size: 14px;
    font-weight: 700;
    color: var(--gold);
    text-align: right;
  }

  /* Badges */
  .bis-badge {
    display: inline-block;
    width: fit-content;
    padding: 2px 6px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    border-radius: 4px;
  }

  .bis-badge-recommended {
    background: rgba(67, 160, 71, 0.2);
    color: #66bb6a;
    border: 1px solid rgba(67, 160, 71, 0.4);
  }

  .bis-badge-situational {
    background: rgba(255, 152, 0, 0.15);
    color: #ffa726;
    border: 1px solid rgba(255, 152, 0, 0.3);
  }

  .bis-badge-sim {
    padding: 2px 7px;
    background: rgba(244, 200, 66, 0.15);
    border: 1px solid rgba(244, 200, 66, 0.4);
    border-radius: 4px;
    color: var(--gold);
    font-family: 'Outfit', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3px;
    text-transform: none;
  }

  /* Encantos */
  .bis-item-enchant {
    display: flex;
    align-items: center;
