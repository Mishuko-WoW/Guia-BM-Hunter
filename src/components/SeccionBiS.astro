---
import { getSectionReviewDate } from '../lib/sectionDates';
import ReviewSourceBox from './ReviewSourceBox.astro';

const reviewDate = getSectionReviewDate([
  'src/components/SeccionBiS.astro',
  'src/content/data/bis.json'
]);
---

<!-- CSS CRÍTICO INLINE - Carga estructura básica PRIMERO -->
<style>
  .bis-slots-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto;
    gap: 24px;
    margin: 32px 0;
    max-width: 100%;
    align-items: stretch;
  }

  .bis-slots-column {
    display: flex;
    flex-direction: column;
    gap: 10px;
    justify-content: space-between;
    min-width: 280px;
  }

  .bis-slot-item {
    position: relative;
    overflow: hidden;
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-radius: 8px;
  }

  .bis-slot-content {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px 10px 16px;
  }

  .bis-slot-icon {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    object-fit: cover;
    border: 1.5px solid var(--border2);
    border-radius: 6px;
  }

  .bis-slot-info {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .bis-sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 320px;
    max-width: 360px;
  }

  .bis-sidebar-section {
    overflow: hidden;
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-radius: 8px;
  }

  .bis-sidebar-items {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px;
  }

  .bis-sidebar-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 8px;
    background: var(--bg4);
    border-radius: 6px;
  }

  .bis-sidebar-icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    object-fit: cover;
    border: 1px solid var(--border2);
    border-radius: 4px;
  }

  .bis-slots-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 0;
    padding: 0;
    min-width: 280px;
    align-self: stretch;
  }

  .bis-spec-artwork {
    position: relative;
    display: flex;
    flex: 1;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    width: 100%;
    min-height: 300px;
    padding-bottom: 20px;
    overflow: hidden;
    border-radius: 8px;
  }

  .bis-weapon-slot {
    width: 100%;
  }

  .bis-progress-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 20px 0 24px;
    padding: 12px 16px;
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-radius: 8px;
  }

  .bis-progress-bar-bg {
    flex: 1;
    height: 12px;
    overflow: hidden;
    background: var(--bg4);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .bis-progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent2), var(--accent));
    border-radius: 6px;
    transition: width 0.4s ease;
  }

  .bis-trinket-ranking {
    padding: 18px 24px 14px 24px;
    background: var(--card);
    border: 1.5px solid var(--bg4);
    border-top: none;
    border-radius: 0 0 12px 12px;
  }

  .bis-trinket-ranking table {
    width: 100%;
    margin-bottom: 12px;
    border-collapse: separate;
    border-spacing: 0;
  }

  .bis-slot-icon-link {
    position: relative;
    display: block;
    flex-shrink: 0;
    line-height: 0;
  }

  .bis-sidebar-icon-link {
    display: block;
    flex-shrink: 0;
    line-height: 0;
  }

  @media (max-width: 1400px) {
    .bis-slots-container {
      grid-template-columns: 1fr auto 1fr;
      grid-template-rows: auto auto;
    }

    .bis-sidebar {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 16px;
      max-width: 100%;
    }
  }

  @media (max-width: 900px) {
    .bis-slots-container {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .bis-slots-center {
      order: -1;
    }

    .bis-sidebar {
      grid-template-columns: 1fr;
    }

    .bis-spec-artwork {
      display: none;
    }
  }
</style>

