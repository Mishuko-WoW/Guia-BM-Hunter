---
import OpenerPackLeaderST from './opener/OpenerPackLeaderST.astro';
import OpenerPackLeaderAoe from './opener/OpenerPackLeaderAoe.astro';
import OpenerDarkRangerST from './opener/OpenerDarkRangerST.astro';
import OpenerDarkRangerAoe from './opener/OpenerDarkRangerAoe.astro';
---

<div id="tab-opener" class="tab-panel">
  <h2>Secuencia de Opener</h2>

  <div class="box box-info">
    <div class="box-title">ℹ️ Objetivo del Opener</div>
    Gastar todas las cargas de <span class="sp" data-name="Disparo con púas" data-type="Habilidad activa" data-desc="Tiene 2 cargas. Gástalas todas antes de Cólera de las bestias para posicionar la mascota y cargar Aliado de la naturaleza.">Disparo con púas</span> <strong>antes</strong> de pulsar <span class="sp" data-name="Cólera de las bestias" data-type="Habilidad activa" data-desc="CD principal.">Cólera de las bestias</span> para que <span class="bf" data-name="Escabechina" data-type="Debuff" data-desc="Aplicado por Cólera de las bestias. Tus mascotas infligen sangrado al objetivo durante 12s. Solo se aplica si la mascota está atacando activamente — si no ataca, no hay sangrado y pierdes todo el DPS del efecto.">Escabechina</span> se aplique desde el primer momento y Aliado de la naturaleza esté cargado.
  </div>

  <div class="toggle-wrap">
    <button class="toggle-btn active" onclick="setOpener('st', this)">🎯 Pack Leader — ST</button>
    <button class="toggle-btn" onclick="setOpener('aoe', this)">💥 Pack Leader — AoE/M+</button>
    <button class="toggle-btn" onclick="setOpener('dr-st', this)">🖤 Dark Ranger — ST</button>
    <button class="toggle-btn" onclick="setOpener('dr-aoe', this)">🖤 Dark Ranger — AoE/M+</button>
  </div>

  <OpenerPackLeaderST />

  <OpenerPackLeaderAoe />

  <OpenerDarkRangerST />

  <OpenerDarkRangerAoe />

  <div class="divider"></div>
  <h3>Comprobaciones Pre-Combate</h3>
  <div class="card">
    <div class="card-rows">
      <div class="data-row compact">✅ Marca del cazador al objetivo prioritario.</div>
      <div class="data-row compact">✅ Redirección al tanque (ver pestaña Macros).</div>
      <div class="data-row compact">✅ Mascota invocada y viva.</div>
      <div class="data-row compact">✅ Verifica auto-casts de la mascota.</div>
    </div>
  </div>
</div>
