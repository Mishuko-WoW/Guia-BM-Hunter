---
import '../styles/bm-guide.css';

interface Props {
  title?: string;
}

const { title = 'Beast Mastery Hunter — Guía Midnight S1' } = Astro.props;
const headerIconUrl = 'https://assets.rpglogs.com/img/warcraft/talents/hero/43_full.png';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={headerIconUrl} />
    <link rel="icon" href={headerIconUrl} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-EJY55YHE6Q">
    </script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-EJY55YHE6Q');
    </script>

  </head>
  <body>
    <slot />
  </body>
</html>
